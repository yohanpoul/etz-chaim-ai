# ═══════════════════════════════════════════════════════════════
# Etz Chaim AI — environment template
# ═══════════════════════════════════════════════════════════════
#
# 1. Copy this file : cp .env.example .env
# 2. Fill in the services you want to use. Everything else can stay empty.
# 3. Run `etzchaim onboard` to run the interactive wizard, or edit by hand.
#
# The wizard generates random secrets, detects ports, and applies the
# migrations. You can also pick `etzchaim onboard --non-interactive --preset
# local-only` to get a local-only setup without prompts.

# ═══════════════════════════════════════════════════════════════
# DATABASE — PostgreSQL 16+ with pgvector
# ═══════════════════════════════════════════════════════════════
#
# Two setup paths :
#   (a) You provide your own Postgres instance. Set ETZ_CHAIM_DB_URL below.
#   (b) Let the bundled docker-compose stack manage a container. The wizard
#       will generate POSTGRES_PASSWORD and map POSTGRES_PORT for you.
#
# pgvector must be enabled in the target database :
#   CREATE EXTENSION IF NOT EXISTS vector;

# Path (a) — full URL takes precedence
ETZ_CHAIM_DB_URL=

# Path (b) — individual fields (used when ETZ_CHAIM_DB_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_USER=etz
DB_PASSWORD=
DB_NAME=etz_chaim

# Docker-compose-managed Postgres (only used in path b + compose mode)
POSTGRES_PASSWORD=
POSTGRES_PORT=5433

# ═══════════════════════════════════════════════════════════════
# LLM PROVIDERS
# ═══════════════════════════════════════════════════════════════
#
# Fill in the providers you actually want to use. Any provider with an
# empty key is silently skipped by the dispatcher.
#
# Etz Chaim routes four olamot (reasoning tiers) to providers :
#   Atziluth  — strategic decisions    (frontier model)
#   Briah     — causal reasoning       (thinking-capable)
#   Yetzirah  — general tasks          (mid-tier)
#   Assiah    — fast execution         (small / fast)
# The mapping lives in config.yaml, under profiles.<name>.olamot.

# ── Frontier commercial ───────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# https://console.x.ai
XAI_API_KEY=
# https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ── Aggregators / inference providers ─────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=
# https://console.groq.com/keys
GROQ_API_KEY=
# https://fireworks.ai/api-keys
FIREWORKS_API_KEY=
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ── Enterprise clouds ─────────────────────────────────────────
# AWS Bedrock (LiteLLM format : model="bedrock/anthropic.claude-3-5-sonnet-v2")
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1

# Azure OpenAI (LiteLLM format : model="azure/<deployment-name>")
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-08-01-preview

# ── Open-weight platforms ─────────────────────────────────────
HUGGINGFACE_API_KEY=
NVIDIA_NIM_API_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
REPLICATE_API_TOKEN=

# ── Embeddings-specific ───────────────────────────────────────
# https://dash.voyageai.com
VOYAGE_API_KEY=
# https://jina.ai/embeddings (uses HUGGINGFACE_API_KEY or dedicated)
JINA_API_KEY=

# ── Self-hosted / local inference ─────────────────────────────
# Ollama (https://ollama.com) — default for the `local_only` profile
OLLAMA_HOST=http://localhost:11434

# vLLM (https://docs.vllm.ai) — OpenAI-compatible endpoint
VLLM_HOST=
VLLM_API_KEY=

# LM Studio — OpenAI-compatible local server
LMSTUDIO_HOST=

# LocalAI — OpenAI-compatible local server
LOCALAI_HOST=

# ── Subscription-based (OAuth, no API key) ────────────────────
# These toggles route olamot.generate through a third-party CLI tool
# authenticated on the host. The CLIs cannot run inside Docker (browser
# OAuth), so these profiles are host-only.
#
# Claude Code CLI — Anthropic Console OAuth (Claude Max plan).
# Install : npm install -g @anthropic-ai/claude-code   ;   then : claude
USE_CLAUDE_CODE_CLI=0

# Codex CLI — ChatGPT OAuth (Plus / Team / Enterprise plan).
# Install : npm install -g @openai/codex               ;   then : codex
USE_CODEX_CLI=0

# Gemini CLI — Google account OAuth (free tier 1000 req/day, paid above).
# Install : npm install -g @google/gemini-cli          ;   then : gemini
USE_GEMINI_CLI=0

# GitHub Copilot CLI — GitHub OAuth (Copilot subscription).
# Install : gh extension install github/gh-copilot     ;   then : gh auth login
USE_COPILOT_CLI=0

# ═══════════════════════════════════════════════════════════════
# EMBEDDINGS
# ═══════════════════════════════════════════════════════════════
# Provider : ollama | openai | cohere | voyage | jina | huggingface
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# ═══════════════════════════════════════════════════════════════
# WEB & AUTH
# ═══════════════════════════════════════════════════════════════
# API key for /api/* endpoints. Wizard generates 32 random chars.
# If empty AND ETZ_CHAIM_ALLOW_ANON != 1, /api/* returns 503 fail-closed.
ETZ_CHAIM_API_KEY=

# Flask session secret. Wizard generates 32 random chars.
ETZ_CHAIM_SECRET_KEY=

# Allow anonymous dashboard access (1 = yes, 0 = no). Default 0.
ETZ_CHAIM_ALLOW_ANON=0

# Web port (auto-detected : first free in 8080-8099)
WEB_PORT=8080

# CORS origins (comma-separated, defaults to same-origin only)
ETZ_CHAIM_CORS_ORIGINS=

# ═══════════════════════════════════════════════════════════════
# OBSERVABILITY
# ═══════════════════════════════════════════════════════════════
# Log level : DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Sentry DSN (leave empty to disable error tracking)
SENTRY_DSN=

# OpenTelemetry OTLP endpoint (leave empty to disable tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=etz-chaim-ai

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════
# MazalEngine rectification mode : observe | suggest | act
# Observe for 2-4 weeks before switching to `act`.
MAZAL_RECTIFICATION_MODE=observe

# Daemon auto-improvement (hour 0-23 local time)
DAEMON_AUTO_IMPROVE_HOUR=21
DAEMON_AUTO_IMPROVE_MAX_CYCLES=10
DAEMON_AUTO_IMPROVE_TIMEOUT=300

# ═══════════════════════════════════════════════════════════════
# RUNTIME
# ═══════════════════════════════════════════════════════════════
# Timezone (IANA format)
TZ=UTC

# Package version (read-only, set by package)
ETZCHAIM_VERSION=0.2.0
